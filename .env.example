# Environment variables for Docker Compose
# Copy this to .env and customize for your deployment

# ── PostgreSQL ──
POSTGRES_DB=creditrisk
POSTGRES_USER=creditrisk_user
POSTGRES_PASSWORD=creditrisk_pass

# ── Django ──
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string-in-production
DJANGO_DEBUG=False

# ── ML Service ──
MODEL_REGISTRY_DIR=/app/models/registry
