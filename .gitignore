# ─── Python ───────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
dist/
build/
.eggs/
*.egg

# ─── Virtual Environment ─────────────────────
venv/
env/
.venv/

# ─── IDE ──────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ─── OS ───────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ─── Environment Variables ────────────────────
.env
!.env.example

# ─── ML Models & Large Files ─────────────────
# NOTE: Model .pkl files are INCLUDED (~1.7MB total)
# because Render needs them to serve predictions.
# Only exclude the registry subdirectory.
models/registry/
!models/*.pkl

# ─── Data Files ──────────────────────────────
data/*.csv
data/*.parquet
data/*.xlsx
data/*.db
data/processed/
!data/README.md

# ─── Results (keep reports, skip large files) ─
results/*.png
results/*.jpg

# ─── Django ──────────────────────────────────
*.sqlite3
db.sqlite3
staticfiles/
media/

# ─── Docker ──────────────────────────────────
*.log

# ─── Jupyter ─────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ─── Misc ────────────────────────────────────
*.bak
*.tmp
